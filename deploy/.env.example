NEXT_PUBLIC_ASSET_BASE_URL=https://storage.googleapis.com/audeobox-cdn/videobox
NEXT_PUBLIC_RENDER_API_BASE=/api/render
NEXT_PUBLIC_FEED_BASE_URL=/audeobox-feeds

VIDEOBOX_BIND_HOST=127.0.0.1
VIDEOBOX_WEB_PORT=3100
VIDEOBOX_RENDER_PORT=3101

# Chromium tabs Remotion runs in parallel per render. 1 is safe everywhere;
# 2+ gives near-linear speedup on hosts with enough CPU/RAM. Tight WSL/podman
# dev VMs may not survive 2 — watch for zombie chromium processes on the
# first run after a bump. Capped at 8 by the server.
RENDER_CONCURRENCY=1

# Cancel queued/running work if the editor stops polling for this long. The
# editor polls every 2s; three minutes tolerates transient network failures.
RENDER_CLIENT_LEASE_MS=180000
# Cancel a job whose render progress/stage has not advanced for five minutes.
RENDER_STALL_MS=300000
# One active render plus at most two queued renders.
MAX_PENDING_RENDER_JOBS=3
